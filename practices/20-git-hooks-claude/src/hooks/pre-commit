#!/usr/bin/env bash
#
# pre-commit hook — Scan staged files for secrets using Claude
#
# Install:
#   cp pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#

set -euo pipefail

echo "🔍 Running secret scan on staged files..."

# Get list of staged files (excluding deleted files)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=d)

if [[ -z "$STAGED_FILES" ]]; then
  exit 0
fi

FOUND_SECRETS=false

# First pass: Quick regex scan (no Claude needed)
while IFS= read -r file; do
  # Skip binary files
  if file "$file" | grep -q "binary"; then
    continue
  fi

  # Quick pattern matching for common secrets
  if git show ":$file" 2>/dev/null | grep -qEi \
    '(password|secret|api_key|apikey|token|private_key)\s*[=:]\s*["\x27][^\s"'\'']{8,}["\x27]|AKIA[0-9A-Z]{16}|-----BEGIN.*(PRIVATE|RSA|DSA|EC) KEY-----'; then

    echo ""
    echo "⚠️  Potential secret detected in: $file"

    # Second pass: Use Claude for intelligent analysis
    local_analysis=$(git show ":$file" | claude -p "Analyze this file for hardcoded secrets, API keys, passwords, tokens, or sensitive credentials. Be specific about what you found and on which line. If you find secrets, start your response with 'SECRET_FOUND:'. If the file is clean, start with 'CLEAN:'. Be concise." --allowedTools "" --max-turns 1 2>/dev/null || echo "Error analyzing file")

    if echo "$local_analysis" | grep -q "^SECRET_FOUND:"; then
      echo "❌ SECRET FOUND in $file:"
      echo "$local_analysis" | sed 's/^SECRET_FOUND://'
      FOUND_SECRETS=true
    else
      echo "  ℹ️  Pattern matched but Claude analysis says it's safe."
    fi
  fi
done <<< "$STAGED_FILES"

if [[ "$FOUND_SECRETS" == true ]]; then
  echo ""
  echo "═══════════════════════════════════════"
  echo "❌ COMMIT BLOCKED: Secrets detected!"
  echo ""
  echo "Options:"
  echo "  1. Remove the secrets and use environment variables"
  echo "  2. Add the file to .gitignore"
  echo "  3. Skip this check: git commit --no-verify (NOT recommended)"
  echo "═══════════════════════════════════════"
  exit 1
fi

echo "✅ No secrets detected. Proceeding with commit."
exit 0
