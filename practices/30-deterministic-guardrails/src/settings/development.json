{
  "$schema": "https://raw.githubusercontent.com/anthropics/claude-code/main/settings-schema.json",
  "_comment": "Development environment — warnings instead of blocks, fewer restrictions",

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hook": "bash src/hooks/protect-files.sh",
        "_comment": "Warn when editing protected files (still blocks in dev)"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hook": "bash src/hooks/auto-format.sh",
        "_comment": "Auto-format after every file edit"
      }
    ]
  },

  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit*)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep"
    ]
  }
}
